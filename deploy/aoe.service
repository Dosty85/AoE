[Unit]
Description=AoE RTS game server (static client + WebSocket)
After=network.target

[Service]
Type=simple
User=aoe
WorkingDirectory=/opt/aoe
Environment=PORT=80
Environment=STATIC_DIR=/opt/aoe/dist
ExecStart=/usr/bin/env node /opt/aoe/dist-server/server.cjs
Restart=always
RestartSec=2
# umožní non-root uživateli bindnout port < 1024 (80)
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
